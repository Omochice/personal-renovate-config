{
	"name": "@Omochice/personal-renovate-config",
	"version": "1.16.0",
	"private": true,
	"description": "renovate configuration for me(experimental)",
	"keywords": [
		"renovate"
	],
	"license": "zlib",
	"author": "Omochice",
	"scripts": {
		"fmt": "npm-run-all fmt:package fmt:json",
		"fmt:json": "biome format ./ --write",
		"fmt:package": "sort-package-json",
		"test": "npm-run-all test:*",
		"test:validate": "renovate-config-validator --strict default.json nix.json mise.json playwright.json replacement/*.json grouping/*.json"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.3",
		"jsonata": "2.2.1",
		"npm-run-all2": "9.0.2",
		"re2": "1.26.0",
		"renovate": "43.257.5",
		"sort-package-json": "4.0.0",
		"vitest": "4.1.10",
		"yaml": "2.9.0"
	},
	"packageManager": "pnpm@11.11.0",
	"pnpm": {
		"onlyBuiltDependencies": [
			"@biomejs/biome",
			"esbuild",
			"re2"
		],
		"ignoredBuiltDependencies": [
			"better-sqlite3",
			"core-js-pure",
			"dtrace-provider",
			"protobufjs"
		]
	}
}
