{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"description": "update $schema for oxfmt and oxlint",
	"customManagers": [
		{
			"customType": "jsonata",
			"fileFormat": "json",
			"managerFilePatterns": ["/(^|/)\\.oxlintrc(\\.json)?$/"],
			"matchStrings": [
				"{ 'currentValue': $split($split($.'$schema', '/')[-4], '_v')[-1] }"
			],
			"datasourceTemplate": "npm",
			"depNameTemplate": "oxlint"
		},
		{
			"customType": "jsonata",
			"fileFormat": "json",
			"managerFilePatterns": ["/(^|/)\\.oxfmtrc\\.json$/"],
			"matchStrings": [
				"{ 'currentValue': $split($split($.'$schema', '/')[-4], '_v')[-1] }"
			],
			"datasourceTemplate": "npm",
			"depNameTemplate": "oxfmt"
		}
	]
}
